#!/usr/bin/env bash
# One-command interactive shell: ensure container is up, then attach.
# (docker compose up does not attach stdin to the container reliably.)
# Start gateway inside: openclaw gateway --port 18789 --verbose --bind lan
set -e
cd "$(dirname "$0")"

G=$'\033[32m' D=$'\033[2m' R=$'\033[0m'

printf "${G}⚡ Building & starting OpenClaw container...${R}\n"
printf "${D}   Tip: first build pulls ~500 MB base image. Rebuilds are cached and fast.${R}\n"
printf "${D}   Force rebuild: docker compose build --no-cache${R}\n"

printf "${G}🧹 Stopping previous container...${R}\n"
docker compose down -t 1 &> /dev/null
docker compose up --build &> /dev/null &
printf "${G}ᗧ··· Waiting to start${R}"
while [ "$(docker inspect -f '{{.State.Running}}' openclaw 2>/dev/null)" != "true" ]; do
  printf "${G}.${R}"
  sleep 1
done
printf " ${G}ready!${R}\n"
printf "\n${G}>>>>>>>>>>>>>>>>>>>  Déjà vu and Have a lot of fun!  <<<<<<<<<<<<<<<<<<<${R}\n"
C=$'\033[36m' G=$'\033[32m' Y=$'\033[33m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m' RED=$'\033[1;31m'
W=62; rule=$(printf '═%.0s' $(seq 1 $W))
p() { local s; s=$(printf '%s' "$1" | sed $'s/\033\\[[0-9;]*m//g'); printf '%s%s%*s%s\n' "${C}║${R}" "$1" "$((W-${#s}))" "" "${C}║${R}"; }
hr() { printf '%s%s%s%s%s\n' "$C" "$1" "$rule" "$2" "$R"; }
echo ""
hr "╔" "╗"
p "  ${B}OpenClaw Container${R}"
hr "╠" "╣"
p "  ${G}1.${R} openclaw onboard                    ${D}(first time only)${R}"
p "  ${G}2.${R} openclaw gateway --port 18789 --verbose  ${D}(every time)${R}"
p "  ${RED}3. Ctrl+P, Ctrl+Q to exit (gateway keeps running)${R}"
hr "╠" "╣"
p "  ${G}Channels & Devices${R}"
p "    openclaw channel add telegram --botToken ${D}<token>${R}"
p "    openclaw devices list"
p "    openclaw devices approve"
hr "╠" "╣"
p "  ${G}Useful Commands${R}"
p "    openclaw config get     │  openclaw status"
p "    openclaw logs           │  openclaw version"
p "    openclaw help           │  screen -S gw bash ${D}(multiplexer)${R}"
hr "╠" "╣"
p "  ${D}Attach:  docker attach openclaw${R}"
p "  ${D}Shell:   docker exec -it openclaw bash${R}"
p "  ${D}Logs:    docker logs -f openclaw${R}"
hr "╚" "╝"

exec docker compose attach openclaw
