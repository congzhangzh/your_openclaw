# =============================================================================
# OpenClaw Docker Configuration
# =============================================================================
# This file controls DOCKER-LEVEL settings only.
# API keys and model config go through `openclaw config set` (stored in ~/.openclaw/)
#
# Copy to .env:  cp .env.example .env
# =============================================================================

# # Gateway port (default: 18789)
# OPENCLAW_PORT=18789

# # Data directory on HOST (mounted into container as /root/.openclaw)
# # This is where your config, API keys, workspace, and logs live.
# # Back this up. It's your AI's brain.
# OPENCLAW_DATA=~/.openclaw
